// Class hierarchy and ownership.
// - Solid edges:    "owns" (unique_ptr).
// - Dashed edges:   "is-a" (inheritance).
digraph OwnershipDiagram {
  rankdir=TB;
  nodesep=0.4;
  ranksep=0.6;
  node [shape=box, style="rounded,filled", fillcolor="#FFFFFF",
        fontname="Helvetica", fontsize=11];
  edge [fontname="Helvetica", fontsize=9];

  // Facade and core ---------------------------------------------------------
  RobotSystem [label="RobotSystem", fillcolor="#FFA500"];
  Controller  [label="Controller",  fillcolor="#FFD27F"];
  IK          [label="InverseKinematics\n(OSQP)", fillcolor="#FFD27F"];
  Kinematics  [label="KinematicsEngine\n(Pinocchio)", fillcolor="#B8E6B8"];

  // Hardware abstraction ----------------------------------------------------
  HAL    [label="HardwareInterface", fillcolor="#D0E0FF"];
  Mujoco [label="MujocoDriver",      fillcolor="#FFFFFF"];
  Servo  [label="ServoDriver",       fillcolor="#FFFFFF"];

  // Tasks -------------------------------------------------------------------
  Task     [label="Task",        fillcolor="#FCE5B4"];
  Frame    [label="FrameTask",   fillcolor="#FFFFFF"];
  Posture  [label="PostureTask", fillcolor="#FFFFFF"];
  Damping  [label="DampingTask", fillcolor="#FFFFFF"];

  // Limits ------------------------------------------------------------------
  Limit    [label="Limit",              fillcolor="#FCE5B4"];
  VelLim   [label="VelocityLimit",      fillcolor="#FFFFFF"];
  CfgLim   [label="ConfigurationLimit", fillcolor="#FFFFFF"];

  // Barriers ----------------------------------------------------------------
  Barrier  [label="Barrier",               fillcolor="#FCE5B4"];
  PosBar   [label="PositionBarrier",       fillcolor="#FFFFFF"];
  SphBar   [label="BodySphericalBarrier",  fillcolor="#FFFFFF"];

  // GUI ---------------------------------------------------------------------
  GUI [label="Gui", fillcolor="#B8E6B8"];

  // Ownership (solid) -------------------------------------------------------
  RobotSystem -> Controller   [label="owns"];
  RobotSystem -> Kinematics   [label="owns"];
  RobotSystem -> HAL          [label="owns"];
  Controller  -> IK           [label="owns"];
  Controller  -> Frame        [label="owns (built-in)"];
  Controller  -> Posture      [label="owns (built-in)"];
  Controller  -> Damping      [label="owns (built-in)"];
  Controller  -> VelLim       [label="owns (built-in)"];
  Controller  -> CfgLim       [label="owns (built-in)"];
  GUI         -> RobotSystem  [label="non-owning", style=dotted, dir=back];

  // Inheritance (dashed) ----------------------------------------------------
  Mujoco  -> HAL     [style=dashed, arrowhead=onormal];
  Servo   -> HAL     [style=dashed, arrowhead=onormal];
  Frame   -> Task    [style=dashed, arrowhead=onormal];
  Posture -> Task    [style=dashed, arrowhead=onormal];
  Damping -> Task    [style=dashed, arrowhead=onormal];
  VelLim  -> Limit   [style=dashed, arrowhead=onormal];
  CfgLim  -> Limit   [style=dashed, arrowhead=onormal];
  PosBar  -> Barrier [style=dashed, arrowhead=onormal];
  SphBar  -> Barrier [style=dashed, arrowhead=onormal];

  // Layout hints ------------------------------------------------------------
  { rank=same; Frame; Posture; Damping; }
  { rank=same; VelLim; CfgLim; }
  { rank=same; PosBar; SphBar; }
  { rank=same; Mujoco; Servo; }
}
