// Top-down system view: configuration -> facade -> subsystems -> outputs.
digraph SystemDiagram {
  rankdir=TB;
  splines=ortho;
  nodesep=0.45;
  ranksep=0.55;
  node [fontname="Helvetica", fontsize=11];
  edge [fontname="Helvetica", fontsize=9];

  // Inputs ------------------------------------------------------------------
  subgraph cluster_inputs {
    label="Configuration";
    labelloc=t;
    color="#9370DB";
    penwidth=1.5;
    fillcolor="#EEE6FA";
    style="rounded,filled";

    Scene  [label="MJCF scene",       shape=box, style="rounded,filled", fillcolor="#FFFFFF"];
    Model  [label="URDF / MJCF\nrobot model", shape=box, style="rounded,filled", fillcolor="#FFFFFF"];
    Config [label="RobotConfig",      shape=box, style="rounded,filled", fillcolor="#FFFFFF"];
  }

  // Facade ------------------------------------------------------------------
  RobotSystem [label="RobotSystem\n(public API)",
               shape=box, style="rounded,filled",
               fillcolor="#FFA500", fontcolor="#1a1a1a", penwidth=1.5];

  // Subsystems --------------------------------------------------------------
  subgraph cluster_subsystems {
    label="Internal subsystems";
    labelloc=t;
    color="#606060";
    penwidth=1.5;
    fillcolor="#F0F0F0";
    style="rounded,filled";

    Hardware   [label="HardwareInterface\n(Mujoco / Servo)",
                shape=box, style="rounded,filled", fillcolor="#B8E6B8"];
    Kinematics [label="KinematicsEngine\n(Pinocchio FK + Jacobians)",
                shape=box, style="rounded,filled", fillcolor="#B8E6B8"];
    Controller [label="Controller\n+ InverseKinematics (OSQP)",
                shape=box, style="rounded,filled", fillcolor="#B8E6B8"];
    GUI        [label="Gui\n(ImGui + viewport)",
                shape=box, style="rounded,filled", fillcolor="#B8E6B8"];
  }

  // Outputs -----------------------------------------------------------------
  subgraph cluster_output {
    label="Output";
    labelloc=t;
    color="#4B0082";
    penwidth=1.5;
    fillcolor="#E8E0F0";
    style="rounded,filled";

    Commands [label="Joint commands",      shape=box, style="rounded,filled", fillcolor="#DDA0DD"];
    Frame    [label="Rendered viewport",   shape=box, style="rounded,filled", fillcolor="#DDA0DD"];
  }

  // Edges -------------------------------------------------------------------
  Scene  -> RobotSystem;
  Model  -> RobotSystem;
  Config -> RobotSystem;

  RobotSystem -> Hardware;
  RobotSystem -> Kinematics;
  RobotSystem -> Controller;
  RobotSystem -> GUI;

  Controller -> Hardware [label="q_cmd"];
  Hardware   -> Commands;
  GUI        -> Frame;
}
